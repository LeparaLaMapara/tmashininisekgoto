# ============================================================
# Thabang Neural Observatory — environment variables
# ============================================================

# --- Gemini (chat + embeddings) ---
# Read by @ai-sdk/google for both streamText and embeddings.
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
# Same value; used by @google/genai in Phase 2 node scripts (video/PDF ingestion).
GEMINI_API_KEY=your-gemini-api-key

# --- Supabase (project zbdsqvpxpsygbuqnuekm, shared) ---
NEXT_PUBLIC_SUPABASE_URL=https://zbdsqvpxpsygbuqnuekm.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- RAG ---
# Master switch. When false, /ai falls back to the static knowledge base.
RAG_ENABLED=true
# Tenancy slug stamped on every KB row and used as match_kb_chunks filter_app.
RAG_APP_SLUG=tmashininisekgoto
# Shared secret guarding POST /api/admin/* (reindex, upload). Required.
ADMIN_TOKEN=generate-a-long-random-string
