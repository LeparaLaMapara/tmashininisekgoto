# ============================================================
# Thabang Neural Observatory — environment variables
# ============================================================

# --- Gemini (chat + embeddings) ---
# Read by @ai-sdk/google for both streamText and embeddings.
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
# Same value; used by @google/genai in Phase 2 node scripts (video/PDF ingestion).
GEMINI_API_KEY=your-gemini-api-key

# --- Supabase (site DB; may differ from the KB project) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- KB project (where the RAG tables live). Defaults baked into lib/rag/db.ts
# to zbdsqvpxpsygbuqnuekm + its public anon key; override here to relocate. ---
# KB_SUPABASE_URL=https://zbdsqvpxpsygbuqnuekm.supabase.co
# KB_SUPABASE_ANON_KEY=sb_publishable_...

# --- RAG ---
# Retrieval is ON by default. Set to false as a kill-switch to fall back to the
# static knowledge base.
# RAG_ENABLED=false
# Tenancy slug stamped on every KB row and used as match_kb_chunks filter_app.
RAG_APP_SLUG=tmashininisekgoto
# Shared secret guarding POST /api/admin/* (reindex, upload). Required.
ADMIN_TOKEN=generate-a-long-random-string
